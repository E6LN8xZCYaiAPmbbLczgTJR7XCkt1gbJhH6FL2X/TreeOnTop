local function teleportToTarget()
    local target = killerTargetPlayer
    if not target then return end
    local targetChar = getCharacter(target)
    local localChar = getCharacter(getLocalPlayer())
    local targetHRP = getHRP(targetChar)
    local localHRP = getHRP(localChar)
    if targetHRP and localHRP then
        localHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3)
    end
end
local function startKillerFollow()
    if killerFollowConnection then return end
    killerFollowConnection = Services.RunService.Heartbeat:Connect(function()
        local target = killerTargetPlayer
        local localPlayer = getLocalPlayer()
        if not killerFollowEnabled or not target then
            killerFollowConnection:Disconnect()
            killerFollowConnection = nil
            clearKillerAttachment()
            return
        end
        local targetChar = getCharacter(target)
        local localChar = getCharacter(localPlayer)
        local targetHum = getHumanoid(targetChar)
        if targetHum and targetHum.Health <= 0 then
            clearKillerAttachment()
            return
        end
        local targetHRP = getHRP(targetChar)
        local localHRP = getHRP(localChar)
        if targetHRP and localHRP then
            local behindCFrame = targetHRP.CFrame * CFrame.new(0, 0, 3)
            localHRP.CFrame = behindCFrame
            localHRP.AssemblyLinearVelocity = Vector3.zero
            localHRP.AssemblyAngularVelocity = Vector3.zero
        end
    end)
end
