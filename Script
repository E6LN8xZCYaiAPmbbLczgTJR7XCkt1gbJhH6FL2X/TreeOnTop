_G.fastHitActive = _G.fastHitActive or false
_G.autoPunchLoopRunning = _G.autoPunchLoopRunning or false
local function getCharacter()
	local char = LocalPlayer.Character
	while not char or not char.Parent do
		char = LocalPlayer.CharacterAdded:Wait()
		task.wait()
	end
	return char
end
local function getPunch()
	local char = getCharacter()
	local backpack = LocalPlayer:FindFirstChild("Backpack")
	local punch =
		char:FindFirstChild("Punch")
		or (backpack and backpack:FindFirstChild("Punch"))
	if punch and punch.Parent ~= char then
		pcall(function()
			punch.Parent = char
		end)
	end
	return punch
end
local function startAutoPunch()
	if _G.autoPunchLoopRunning then
		return
	end
	_G.autoPunchLoopRunning = true
	task.spawn(function()
		while true do
			if _G.fastHitActive then
				pcall(function()
					local char = getCharacter()
					if not char then
						return
					end
					local hum = char:FindFirstChildOfClass("Humanoid")
					if not hum or hum.Health <= 0 then
						return
					end
					local punch = getPunch()
					if not punch then
						return
					end
					for _, v in ipairs(punch:GetDescendants()) do
						if v:IsA("NumberValue")
							or v:IsA("IntValue") then
							local n = string.lower(v.Name)
							if n:find("cooldown")
								or n:find("attack")
								or n:find("speed")
								or n:find("time")
								or n:find("delay") then
								v.Value = 0
							end
						end
					end
					if punch:FindFirstChild("attackTime") then
						punch.attackTime.Value = 0
					end
					for i = 1, 10 do
						punch:Activate()
					end
					if LocalPlayer:FindFirstChild("muscleEvent") then
						for i = 1, 10 do
							LocalPlayer.muscleEvent:FireServer("punch", "rightHand")
							LocalPlayer.muscleEvent:FireServer("punch", "leftHand")
						end
					end
				end)
			end
			task.wait(0.02)
		end
	end)
	LocalPlayer.CharacterAdded:Connect(function()
		repeat task.wait() until LocalPlayer.Character
		if _G.fastHitActive then
			task.wait(1)
			pcall(function()
				local punch = getPunch()
				if punch then
					punch.Parent = LocalPlayer.Character
				end
			end)
		end
	end)
end
startAutoPunch()
