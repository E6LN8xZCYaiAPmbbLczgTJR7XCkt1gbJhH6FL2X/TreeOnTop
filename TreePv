local function kill(target)
    if not alive(target) or not char():FindFirstChild("LeftHand") then return end
    pcall(function()
        local lh = char().LeftHand
        firetouchinterest(target.Character.HumanoidRootPart, lh, 0)
        firetouchinterest(target.Character.HumanoidRootPart, lh, 1)
        punch()
    end)
end

