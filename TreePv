local function fmt(n)
    if n >= 1e15 then return ("%.1fqa"):format(n/1e15)
    elseif n >= 1e12 then return ("%.1ft"):format(n/1e12)
    elseif n >= 1e9  then return ("%.1fb"):format(n/1e9)
    elseif n >= 1e6  then return ("%.1fm"):format(n/1e6)
    elseif n >= 1e3  then return ("%.1fk"):format(n/1e3)
    else return ("%.1f"):format(n) end
end

local function fmtComma(n)
    local s = tostring(math.floor(n))
    while true do
        local k; s, k = s:gsub("^(-?%d+)(%d%d%d)", "%1,%2")
        if k == 0 then break end
    end
    return s
end

local function calc1(p)
    if not p then return 0 end
    local dur = p:FindFirstChild("Durability", true)
    if not dur or not dur:IsA("IntValue") then
        return 0
    end
    local mul = 1
    local ultimates = p:FindFirstChild("ultimatesFolder", true)
    if ultimates then
        local ih = ultimates:FindFirstChild("Infernal Health")
        if ih then
            mul += ih.Value * 0.15
        end
    end
    local equippedPets = p:FindFirstChild("equippedPets", true)
    if equippedPets then
        for _, v in ipairs(equippedPets:GetChildren()) do
            if v:IsA("ObjectValue") and v.Value then
                local n = v.Value.Name:lower()
                if n:find("mighty", 1, true) and n:find("monster", 1, true) then
                    mul += 0.5
                elseif n:find("small", 1, true) and n:find("fry", 1, true) then
                    mul += 0.25
                end
            end
        end
    end
    return dur.Value * mul
end

local function calc2(p)
    if not p then return 0 end
    local ls = p:FindFirstChild("leaderstats")
    if not ls or not ls:FindFirstChild("Strength") then return 0 end
    local base = ls.Strength.Value * 0.06666666666666667
    local mul  = 1
    if p:FindFirstChild("ultimatesFolder") then
        local dd = p.ultimatesFolder:FindFirstChild("Demon Damage")
        if dd then mul += 0.1 * (dd.Value or 0) end
    end
    if p:FindFirstChild("equippedPets") then
        for _, v in ipairs(p.equippedPets:GetChildren()) do
            if v:IsA("ObjectValue") and v.Value then
                local n = v.Value.Name:lower()
                if n:match("wild")  and n:match("wizard")   then mul += 0.5  end
                if n:match("chaos") and n:match("sorcerer")  then mul += 0.25 end
            end
        end
    end
    return base * mul
end

local lastHitters = {}
local hitScores = {}

local function addToBlacklist(name)
    if not name or inList(g.blacklist, name) then return end
    table.insert(g.blacklist, name)
end

local RANGE = 15
local CONFIDENCE = 3
local TOLERANCE = 0.02

local damageEvent = rEvents.guiDamageEvent

damageEvent.OnClientEvent:Connect(function(kind, target, dmg)
    if kind ~= "damageShow" then return end
    if not autoBlacklist then return end
    if typeof(dmg) ~= "number" or dmg <= 0 then return end
    local myHrp = hrp()
    if not myHrp or target ~= myHrp then return end
    local candidates = {}
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl == lp then continue end
        local plChar = pl.Character
        if not plChar then continue end
        local plHrp = plChar:FindFirstChild("HumanoidRootPart")
        if not plHrp then continue end
        if (plHrp.Position - myHrp.Position).Magnitude > RANGE then continue end
        local dm = calc2(pl)
        if dm > 0 then
            table.insert(candidates, {pl = pl, dm = dm, diff = math.abs(dm - dmg)})
        end
    end
    if #candidates == 0 then return end
    table.sort(candidates, function(a, b) return a.diff < b.diff end)
    local top = candidates[1]
    if top.diff <= dmg * TOLERANCE then
        if not lastHitters[top.pl] or tick() - lastHitters[top.pl] > 8 then
            addToBlacklist(top.pl.Name)
            lastHitters[top.pl] = tick()
            hitScores = {}
        end
        return
    end
    local ambiguous = false
    for i = 2, #candidates do
        if candidates[i].diff <= top.diff + (dmg * TOLERANCE) then
            ambiguous = true
            break
        end
    end
    hitScores[top.pl] = (hitScores[top.pl] or 0) + 1
    if not ambiguous or hitScores[top.pl] >= CONFIDENCE then
        if not lastHitters[top.pl] or tick() - lastHitters[top.pl] > 8 then
            addToBlacklist(top.pl.Name)
            lastHitters[top.pl] = tick()
            hitScores = {}
        end
    end
end)

