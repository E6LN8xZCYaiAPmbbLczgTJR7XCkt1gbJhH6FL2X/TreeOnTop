        l.name.Position = sp - Vector2.new(0, 45)
        l.name.Visible = true
        l.hp.Text = "HP: "  .. fmt(calc1(p))
        l.hp.Position = sp - Vector2.new(0, 20)
        l.hp.Visible = true
        l.dmg.Text = "DMG: " .. fmt(calc2(p))
        l.dmg.Position = sp + Vector2.new(0, 5)
        l.dmg.Visible = true
    end
end)
