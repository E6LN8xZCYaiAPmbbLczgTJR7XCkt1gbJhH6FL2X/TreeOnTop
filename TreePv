local function on()
    if not w.on or not char() then return end
    if w.conn then w.conn:Disconnect() end
    part.CanCollide = true
    w.conn = Run.RenderStepped:Connect(function()
        local r = hrp()
        if r then part.CFrame = CFrame.new(r.Position.X, -9.5, r.Position.Z) end
    end)
end

local function off()
    if w.conn then w.conn:Disconnect(); w.conn = nil end
    part.CanCollide = false
    part.Position = Vector3.new(0, -1e4, 0)
end

