local function equipPets(name)
    for _, f in pairs(lp.petsFolder:GetChildren()) do
        if f:IsA("Folder") then
            for _, p in pairs(f:GetChildren()) do
                rEvents.equipPetEvent:FireServer("unequipPet", p)
            end
        end
    end
    task.wait(0.003)
    local found = {}
    for _, p in pairs(lp.petsFolder.Unique:GetChildren()) do
        if p.Name == name then table.insert(found, p) end
    end
    for i = 1, math.min(8, #found) do
        rEvents.equipPetEvent:FireServer("equipPet", found[i])
        task.wait(0.003)
    end
    return found
end

