local function newDraw(size, color)
    local t = Drawing.new("Text")
    t.Visible = false
    t.Color = color
    t.Outline = false
    t.OutlineColor = Color3.fromRGB(255, 0, 0)
    t.Size = size
    t.Font = 1
    t.Center = true
    t.Transparency = 3
    return t
end

local function getLabels(p)
    if not esp.labels[p] then
        esp.labels[p] = {
            name = newDraw(20, Color3.fromRGB(255, 0, 0)),
            hp = newDraw(20, Color3.fromRGB(0, 255, 0)),
            dmg = newDraw(20, Color3.fromRGB(0, 255, 0)),
        }
    end
    return esp.labels[p]
end

local function hideLabels(p)
    if esp.labels[p] then
        for _, l in pairs(esp.labels[p]) do l.Visible = false end
    end
end

local function removeLabels(p)
    if esp.labels[p] then
        for _, l in pairs(esp.labels[p]) do l.Visible = false; l:Remove() end
        esp.labels[p] = nil
    end
end

